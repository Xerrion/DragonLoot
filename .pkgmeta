package-as: DragonLoot
enable-toc-creation: yes
manual-changelog: .release/CHANGELOG.md

move-folders:
  DragonLoot/DragonLoot: DragonLoot
  DragonLoot/DragonLoot_Options: DragonLoot_Options

externals:
  DragonLoot/Libs/Ace3: https://repos.wowace.com/wow/ace3/trunk
  DragonLoot/Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1
  DragonLoot/Libs/LibDBIcon-1.0: https://repos.wowace.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
  DragonLoot/Libs/LibSharedMedia-3.0: https://repos.wowace.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  DragonLoot/Libs/LibAnimate: https://github.com/Xerrion/LibAnimate

ignore:
  - ".git*"
  - .luacheckrc
  - .release
  - scripts
  - "*.md"
  - "*.png"
  - release-please-config.json
  - .release-please-manifest.json
  - spec/
  - scripts/
  - "Assets/*logo*"